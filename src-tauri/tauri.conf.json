{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "LookMD",
  "version": "0.1.1",
  "identifier": "com.local.mdreaderlite",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "LookMD",
        "width": 1180,
        "height": 760,
        "minWidth": 860,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "LookMD - 轻量级 Markdown 阅读器",
    "longDescription": "LookMD 是一个基于 Tauri 2 + React 的 Windows 本地轻量级 Markdown 文件阅读器，支持代码高亮、目录大纲、文件搜索等功能。",
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
